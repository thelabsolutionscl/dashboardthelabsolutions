{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Lab CRM",
  "version": "1.0.0",
  "identifier": "solutions.thelab.dashboard",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "The Lab CRM — Centro de Comando",
        "url": "https://dashboard.thelab.solutions",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "copyright": "© The Lab Solutions",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
