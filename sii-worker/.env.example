# ── Entorno SII ───────────────────────────────────────────────────────────────
# "certificacion" (maullin.sii.cl) o "produccion" (palena.sii.cl)
SII_ENV=certificacion

# ── Datos del emisor (reemplaza por los de TU empresa) ────────────────────────
RUT_EMISOR=TU_RUT_EMISOR
RAZON_SOCIAL=TU_RAZON_SOCIAL
GIRO_EMISOR=TU_GIRO
ACTECO=TU_ACTECO
DIR_EMISOR=TU_DIRECCION
CMNA_EMISOR=TU_COMUNA
CIUDAD_EMISOR=TU_CIUDAD
RESOLUCION_FECHA=AAAA-MM-DD
RESOLUCION_NUMERO=TU_NUMERO_RESOLUCION

# ── Certificado digital (.pfx) ────────────────────────────────────────────────
# NO subas el .pfx al repo. Genera el base64 con: base64 -i tu_cert.pfx | tr -d '\n'
CERT_PFX_PASSWORD=
CERT_PFX_BASE64=PEGAR_BASE64_DEL_PFX_AQUI

# ── Seguridad ─────────────────────────────────────────────────────────────────
# API key para proteger las rutas que emiten/mutan. Si se define, los clientes
# deben enviar el header  X-SII-Key: <valor>.  Si se deja vacía, la API queda
# SIN PROTECCIÓN (se avisa por consola). Genera una con: openssl rand -hex 32
SII_API_KEY=

# Pon "1" para habilitar los endpoints de diagnóstico (/debug, /test-cert,
# /test-token, /test-raw) y el logging detallado (XML firmado, token, respuestas
# del SII). Déjala vacía o distinta de "1" en producción.
SII_DEBUG=

# Origen permitido para CORS (Access-Control-Allow-Origin). Si se deja vacío se
# usa "*" (cualquier origen). RECOMENDADO: fíjalo al dominio de tu dashboard,
# p.ej. https://tu-dashboard.example.com
SII_ALLOW_ORIGIN=

# Puerto del servidor Node (server.js)
PORT=3000
